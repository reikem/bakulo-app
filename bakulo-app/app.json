{
  "expo": {
    "name": "Serenity",
    "slug": "serenity-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "serenity",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#004e63"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.serenity.health",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Serenity usa la cámara para escanear documentos médicos.",
        "NSPhotoLibraryUsageDescription": "Serenity accede a tus fotos para adjuntar imágenes a tus registros.",
        "NSHealthShareUsageDescription": "Serenity lee datos de salud para mejorar tu seguimiento.",
        "NSHealthUpdateUsageDescription": "Serenity escribe datos de salud para sincronizar tus registros."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004e63"
      },
      "package": "com.serenity.health",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "serenity"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#004e63",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Serenity necesita acceso a tus fotos para adjuntar imágenes."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ec97402-e9a4-4c3c-b18c-207cd812cc7d"
      }
    }
  }
}